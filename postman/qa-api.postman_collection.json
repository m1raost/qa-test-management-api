{
  "info": {
    "name": "QA Test Management API",
    "description": "Full collection for testing the QA Test Management API. Import this file into Postman, set the `base_url` variable to `http://localhost:8000`, then run Auth/Register and Auth/Login first — the login request automatically saves your token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/register", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tester@example.com\",\n  \"password\": \"testpassword123\"\n}"
            },
            "description": "Create a new user account. Returns user id and email. Expected status: 201."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('token', json.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/login", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "login"] },
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "tester@example.com" },
                { "key": "password", "value": "testpassword123" }
              ]
            },
            "description": "Login and receive a JWT token. The test script saves the token to the `token` variable automatically. Expected status: 200."
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/me", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "me"] },
            "description": "Returns the currently logged-in user's profile. Expected status: 200."
          }
        }
      ]
    },
    {
      "name": "Test Suites",
      "item": [
        {
          "name": "Create Suite",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/test-suites/", "host": ["{{base_url}}"], "path": ["api", "v1", "test-suites", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Login Feature Tests\",\n  \"description\": \"All tests related to the login flow\"\n}"
            },
            "description": "Create a new test suite. Expected status: 201."
          }
        },
        {
          "name": "List Suites",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/test-suites/", "host": ["{{base_url}}"], "path": ["api", "v1", "test-suites", ""] },
            "description": "List all test suites owned by the current user. Expected status: 200."
          }
        },
        {
          "name": "Get Suite by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/test-suites/1", "host": ["{{base_url}}"], "path": ["api", "v1", "test-suites", "1"] },
            "description": "Get a single test suite by ID. Returns 404 if not found or not owned by you."
          }
        },
        {
          "name": "Update Suite",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/test-suites/1", "host": ["{{base_url}}"], "path": ["api", "v1", "test-suites", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Login Feature Tests — Updated\"\n}"
            },
            "description": "Partially update a test suite. Only provided fields are changed. Expected status: 200."
          }
        },
        {
          "name": "Delete Suite",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/test-suites/1", "host": ["{{base_url}}"], "path": ["api", "v1", "test-suites", "1"] },
            "description": "Delete a test suite. Expected status: 204 (no body)."
          }
        }
      ]
    },
    {
      "name": "Test Cases",
      "item": [
        {
          "name": "Create Test Case",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/test-cases/", "host": ["{{base_url}}"], "path": ["api", "v1", "test-cases", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Verify login with valid credentials\",\n  \"description\": \"Happy-path login test\",\n  \"steps\": \"1. Open /login\\n2. Enter valid email and password\\n3. Click Submit\",\n  \"expected_result\": \"Redirected to dashboard\",\n  \"priority\": \"high\",\n  \"severity\": \"critical\",\n  \"status\": \"active\",\n  \"suite_id\": 1\n}"
            },
            "description": "Create a test case inside a suite. suite_id must belong to the current user. Expected status: 201."
          }
        },
        {
          "name": "List Test Cases by Suite",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/test-cases/?suite_id=1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "test-cases", ""],
              "query": [{ "key": "suite_id", "value": "1" }]
            },
            "description": "List all test cases in a suite. suite_id is required. Expected status: 200."
          }
        },
        {
          "name": "Get Test Case by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/test-cases/1", "host": ["{{base_url}}"], "path": ["api", "v1", "test-cases", "1"] },
            "description": "Get a single test case. Expected status: 200 or 404."
          }
        },
        {
          "name": "Update Test Case",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/test-cases/1", "host": ["{{base_url}}"], "path": ["api", "v1", "test-cases", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"active\",\n  \"priority\": \"critical\"\n}"
            },
            "description": "Partially update a test case. Only provided fields change. Expected status: 200."
          }
        },
        {
          "name": "Delete Test Case",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/test-cases/1", "host": ["{{base_url}}"], "path": ["api", "v1", "test-cases", "1"] },
            "description": "Delete a test case. Expected status: 204."
          }
        }
      ]
    },
    {
      "name": "Test Runs",
      "item": [
        {
          "name": "Create Test Run",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/test-runs/", "host": ["{{base_url}}"], "path": ["api", "v1", "test-runs", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sprint 12 Regression\",\n  \"suite_id\": 1\n}"
            },
            "description": "Start a new test run. suite_id is optional. Expected status: 201."
          }
        },
        {
          "name": "List Test Runs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/test-runs/", "host": ["{{base_url}}"], "path": ["api", "v1", "test-runs", ""] },
            "description": "List all test runs. Expected status: 200."
          }
        },
        {
          "name": "Get Test Run by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/test-runs/1", "host": ["{{base_url}}"], "path": ["api", "v1", "test-runs", "1"] },
            "description": "Get a single test run. Expected status: 200 or 404."
          }
        },
        {
          "name": "Update Test Run",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/test-runs/1", "host": ["{{base_url}}"], "path": ["api", "v1", "test-runs", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"completed\"\n}"
            },
            "description": "Update a test run (e.g. mark as completed). Expected status: 200."
          }
        },
        {
          "name": "Delete Test Run",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/test-runs/1", "host": ["{{base_url}}"], "path": ["api", "v1", "test-runs", "1"] },
            "description": "Delete a test run. Expected status: 204."
          }
        }
      ]
    },
    {
      "name": "Test Results",
      "item": [
        {
          "name": "Record Test Result",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/test-results/", "host": ["{{base_url}}"], "path": ["api", "v1", "test-results", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"run_id\": 1,\n  \"test_case_id\": 1,\n  \"status\": \"passed\",\n  \"notes\": \"Ran on Chrome 120\",\n  \"duration_ms\": 342\n}"
            },
            "description": "Record the result of executing a test case in a run. Status must be one of: passed, failed, skipped, blocked, error. Expected status: 201."
          }
        },
        {
          "name": "List Results by Run",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/test-results/?run_id=1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "test-results", ""],
              "query": [{ "key": "run_id", "value": "1" }]
            },
            "description": "List all results for a specific run. run_id is required. Expected status: 200."
          }
        },
        {
          "name": "Get Result by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/test-results/1", "host": ["{{base_url}}"], "path": ["api", "v1", "test-results", "1"] },
            "description": "Get a single test result. Expected status: 200 or 404."
          }
        },
        {
          "name": "Update Result",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/test-results/1", "host": ["{{base_url}}"], "path": ["api", "v1", "test-results", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"failed\",\n  \"notes\": \"Button was unresponsive on Firefox\"\n}"
            },
            "description": "Update a test result. Expected status: 200."
          }
        },
        {
          "name": "Delete Result",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/test-results/1", "host": ["{{base_url}}"], "path": ["api", "v1", "test-results", "1"] },
            "description": "Delete a test result. Expected status: 204."
          }
        }
      ]
    }
  ]
}
